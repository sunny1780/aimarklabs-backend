{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "api/health.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/api/index"
    },
    {
      "src": "^/health$",
      "dest": "/api/health"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/[...path]"
    }
  ]
}
