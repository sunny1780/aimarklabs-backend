# Frontend (React)
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_METRICOOL_API_URL=https://api.metricool.com/v1
REACT_APP_METRICOOL_API_KEY=your_metricool_api_key_here

# Backend (Instagram overview API - npm run start:api)
# Get token: Meta for Developers → Your App → Tools → Graph API Explorer.
# Token needs: instagram_basic, pages_read_engagement, pages_show_list
INSTAGRAM_ACCESS_TOKEN=your_token

# Use ONE of these for the Instagram account:
# - Instagram Business Account ID (recommended). Find in Meta Business Suite or via API.
BECKLEY_PARTYHALL_IG_USER_ID=your_instagram_business_account_id

# - OR Facebook Page ID. Backend will resolve Page → Instagram Business Account.
# FACEBOOK_PAGE_ID=your_facebook_page_id

INSTAGRAM_GRAPH_VERSION=v20.0

# Optional: per-client IDs for instagram overview endpoint
# party-hall client
FACEBOOK_PAGE_ID=your_party_hall_facebook_page_id
BECKLEY_PARTYHALL_IG_USER_ID=your_party_hall_instagram_business_account_id

# walker-advisor client
WALKER_ADVISOR_FACEBOOK_PAGE_ID=your_walker_facebook_page_id
WALKER_ADVISOR_IG_USER_ID=your_walker_instagram_business_account_id
